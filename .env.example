# Argon2-Hash des App-Passworts. Erzeugen mit:
#   pnpm hash:password <plain>
APP_PASSWORD_HASH=

# Hex-encoded Secret für Session-Cookie-Signatur. Mindestens 64 hex chars (32 bytes).
# Erzeugen mit:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Optional, Default 3030
PORT=3030

# Optional, Default ./data/reisekontor.db
DATABASE_PATH=
