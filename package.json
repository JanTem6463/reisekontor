{
  "name": "reisekontor",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:domain": "vitest run src/domain",
    "lint": "biome check --write src tests scripts",
    "lint:check": "biome check src tests scripts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx scripts/run-migrations.ts",
    "db:generate": "drizzle-kit generate",
    "hash:password": "tsx scripts/hash-password.ts",
    "dev:ui": "pnpm --filter @reisekontor/ui dev",
    "build:ui": "pnpm --filter @reisekontor/ui build",
    "typecheck:ui": "pnpm --filter @reisekontor/ui typecheck",
    "lint:ui": "pnpm --filter @reisekontor/ui lint:check"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/pdfkit": "^0.17.6",
    "@vitest/coverage-v8": "^2.1.9",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.10.0",
    "date-holidays": "^3.30.2",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "hono": "^4.12.25",
    "pdfkit": "^0.19.1",
    "pino": "^10.3.1",
    "tsx": "^4.22.4",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
